{
  "name": "chuhai-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/next-build.cjs",
    "start": "next start",
    "test:parser": "tsx ./scripts/test-streaming-parser.ts",
    "test:report-safety": "tsx ./scripts/test-report-safety.ts",
    "test:auth": "tsx ./scripts/test-auth-api.ts",
    "test:admin-api": "tsx ./scripts/test-admin-api.ts",
    "test:session-drafts": "tsx ./scripts/test-session-drafts.ts",
    "test:provider-api": "tsx ./scripts/test-provider-api.ts",
    "test:report-unlock": "tsx ./scripts/test-report-unlock.ts",
    "test:mcp-api": "tsx ./scripts/test-mcp-api.ts",
    "test:visual-system": "tsx ./scripts/test-visual-system.ts",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run test:parser && npm run test:report-safety && npm run test:auth && npm run test:admin-api && npm run test:session-drafts && npm run test:provider-api && npm run test:report-unlock && npm run test:mcp-api && npm run test:visual-system && npm run build"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  }
}
