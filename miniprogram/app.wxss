/*
 * 罗宾出海分析 Agent — 全局样式 & 视觉设计令牌
 *
 * 色彩矩阵:
 *   主色 #0D9488   — 导航栏、区块标题、主信息
 *   辅色 #0F766E   — 渐变、次级区块
 *   CTA  #10B981   — 鲜薄荷绿，主转化按钮（引导注意力优先级）
 *   背景 #F8FAFC   — 全局底色（与白色卡片拉开区分度）
 *   卡片 #ffffff   — 卡片底色
 *   成功 #059669   — 优势、正向指标
 *   风险 #EA580C   — 风险、注意项
 *   文字 #1E293B   — 正文
 *         #475569   — 次要文字
 *         #64748B   — 提示/placeholder
 *   边框 #E2E8F0   — 未选中边框
 *        #CBD5E1   — 进度条底色
 *   阴影 0 8rpx 32rpx rgba(13,148,136,0.04) — 卡片阴影
 */

/* ── 基础重置 ────────────────────────────────── */
page {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC",
    "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1E293B;
  background-color: #F8FAFC;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* ── 常用工具类 ──────────────────────────────── */
.container {
  padding: 32rpx;
}

.text-center {
  text-align: center;
}

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }

/* ── 通用按钮 ─────────────────────────────────── */
.btn-primary {
  display: block;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
  border-radius: 16rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  background: #CBD5E1;
  color: #64748B;
}

/* CTA 鲜薄荷绿强调按钮 — 用于主转化节点 */
.btn-cta {
  display: block;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  background: linear-gradient(135deg, #10B981, #059669);
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.15);
}

.btn-cta:active {
  opacity: 0.85;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.08);
}

.btn-cta[disabled] {
  background: #CBD5E1;
  color: rgba(255,255,255,0.7);
  box-shadow: none;
}

/* ── 卡片容器 ─────────────────────────────────── */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(13, 148, 136, 0.04);
}

/* ── 安全区适配 ──────────────────────────────── */
.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ── 通用分隔线 ──────────────────────────────── */
.divider {
  height: 1rpx;
  background: #E2E8F0;
  margin: 24rpx 0;
}
