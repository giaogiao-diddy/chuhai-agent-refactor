/*
 * 罗宾出海分析 Agent — 全局样式 & 视觉设计令牌
 *
 * 色彩矩阵:
 *   主色 #1a1a2e   — 导航栏、区块标题、主信息
 *   辅色 #16213e   — 渐变、次级区块
 *   CTA  #c8a45c   — 暖金/铜色，主转化按钮（引导注意力优先级）
 *   背景 #f0f1f5   — 全局底色（与白色卡片拉开区分度）
 *   卡片 #ffffff   — 卡片底色
 *   成功 #2e7d32   — 优势、正向指标
 *   风险 #e65100   — 风险、注意项
 *   文字 #333      — 正文
 *         #555      — 次要文字
 *         #999      — 提示/placeholder（WCAG AA 最低 #999）
 *   边框 #e8e8e8   — 未选中边框
 *        #ddd      — 进度条底色
 *   阴影 0 4rpx 16rpx rgba(0,0,0,0.08) — 卡片阴影
 */

/* ── 基础重置 ────────────────────────────────── */
page {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC",
    "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background-color: #f0f1f5;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* ── 常用工具类 ──────────────────────────────── */
.container {
  padding: 32rpx;
}

.text-center {
  text-align: center;
}

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }

/* ── 通用按钮 ─────────────────────────────────── */
.btn-primary {
  display: block;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

/* CTA 暖金强调按钮 — 用于主转化节点 */
.btn-cta {
  display: block;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a45c 0%, #b89437 100%);
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(200, 164, 92, 0.35);
}

.btn-cta:active {
  opacity: 0.88;
}

.btn-cta[disabled] {
  background: #d4c9a8;
  color: rgba(255,255,255,0.7);
  box-shadow: none;
}

/* ── 卡片容器 ─────────────────────────────────── */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* ── 安全区适配 ──────────────────────────────── */
.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ── 通用分隔线 ──────────────────────────────── */
.divider {
  height: 1rpx;
  background: #e8e8e8;
  margin: 24rpx 0;
}
