/* 罗宾出海分析 Agent — 全局样式 */

/* ── 基础重置 ────────────────────────────────── */
page {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC",
    "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

/* ── 常用工具类 ──────────────────────────────── */
.container {
  padding: 32rpx;
}

.text-center {
  text-align: center;
}

.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }

/* ── 通用按钮 ─────────────────────────────────── */
.btn-primary {
  display: block;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

/* ── 卡片容器 ─────────────────────────────────── */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
