.page {
  min-height: 100vh;
  background: #F8FAFC;
}

.container {
  padding: 40rpx 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx 0;
  color: #64748B;
}

/* ── 标题 ─────────────────────────────────────── */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0F766E;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
}

/* ── 二维码卡片 ───────────────────────────────── */
.qrcode-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-img {
  width: 360rpx;
  height: 360rpx;
  border-radius: 12rpx;
}

.qrcode-placeholder {
  width: 360rpx;
  height: 360rpx;
  border-radius: 12rpx;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #CBD5E1;
}

.qrcode-placeholder-icon {
  margin-bottom: 20rpx;
}

.placeholder-qr-pattern {
  width: 120rpx;
  height: 120rpx;
  background:
    linear-gradient(45deg, #0D9488 25%, transparent 25%),
    linear-gradient(-45deg, #0D9488 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #0D9488 75%),
    linear-gradient(-45deg, transparent 75%, #0D9488 75%);
  background-size: 40rpx 40rpx;
  background-position: 0 0, 0 20rpx, 20rpx -20rpx, -20rpx 0;
  opacity: 0.15;
  border-radius: 8rpx;
}

.qrcode-placeholder-text {
  font-size: 26rpx;
  color: #64748B;
}

.consultant-name {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #475569;
}

/* ── 状态 ─────────────────────────────────────── */
.status-box {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.status-waiting {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #64748B;
}

.waiting-dot-anim {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10B981;
  margin-right: 12rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.12); }
  50% { opacity: 1; box-shadow: 0 0 0 8rpx rgba(16, 185, 129, 0.16); }
}

.status-success {
  font-size: 28rpx;
  color: #059669;
  font-weight: 600;
}

/* ── 按钮 ─────────────────────────────────────── */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-secondary {
  background: #FFFFFF;
  color: #475569;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx;
  border: 1rpx solid #E2E8F0;
}

/* ── 开发工具 ─────────────────────────────────── */
.dev-section {
  margin-top: 60rpx;
  border-top: 2rpx solid #E2E8F0;
  padding-top: 30rpx;
}

.divider {
  text-align: center;
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 20rpx;
}

.btn-dev {
  background: #ECFDF5;
  color: #059669;
  border: 2rpx dashed #10B981;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 20rpx;
}
