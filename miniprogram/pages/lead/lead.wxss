.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  padding: 40rpx 30rpx;
}

/* 加载 */
.loading-box {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* 标题 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

/* 二维码 */
.qrcode-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-img {
  width: 360rpx;
  height: 360rpx;
  border-radius: 12rpx;
}

.qrcode-placeholder {
  width: 360rpx;
  height: 360rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.qrcode-placeholder-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.qrcode-placeholder-text {
  font-size: 26rpx;
  color: #999;
}

.consultant-name {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* 状态 */
.status-box {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.status-waiting {
  font-size: 28rpx;
  color: #999;
}

.status-success {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: #1a1a2e;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 24rpx;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx;
}

/* 开发工具 */
.dev-section {
  margin-top: 60rpx;
  border-top: 2rpx solid #eee;
  padding-top: 30rpx;
}

.divider {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 20rpx;
}

.btn-dev {
  background: #fff3cd;
  color: #856404;
  border: 2rpx dashed #ffc107;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 20rpx;
}
