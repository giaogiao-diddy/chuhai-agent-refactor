.page {
  min-height: 100vh;
  background: #f0f1f5;
}

.container {
  padding: 40rpx 30rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* ── 标题 ─────────────────────────────────────── */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

/* ── 二维码卡片 ───────────────────────────────── */
.qrcode-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-img {
  width: 360rpx;
  height: 360rpx;
  border-radius: 12rpx;
}

.qrcode-placeholder {
  width: 360rpx;
  height: 360rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.qrcode-placeholder-icon {
  margin-bottom: 20rpx;
}

.placeholder-qr-pattern {
  width: 120rpx;
  height: 120rpx;
  background:
    linear-gradient(45deg, #1a1a2e 25%, transparent 25%),
    linear-gradient(-45deg, #1a1a2e 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #1a1a2e 75%),
    linear-gradient(-45deg, transparent 75%, #1a1a2e 75%);
  background-size: 40rpx 40rpx;
  background-position: 0 0, 0 20rpx, 20rpx -20rpx, -20rpx 0;
  opacity: 0.15;
  border-radius: 8rpx;
}

.qrcode-placeholder-text {
  font-size: 26rpx;
  color: #999;
}

.consultant-name {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* ── 状态 ─────────────────────────────────────── */
.status-box {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
}

.status-waiting {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.waiting-dot-anim {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c8a45c;
  margin-right: 12rpx;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.status-success {
  font-size: 28rpx;
  color: #2e7d32;
  font-weight: 600;
}

/* ── 按钮 ─────────────────────────────────────── */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-secondary {
  background: #fff;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx;
  border: 1rpx solid #e8e8e8;
}

/* ── 开发工具 ─────────────────────────────────── */
.dev-section {
  margin-top: 60rpx;
  border-top: 2rpx solid #eee;
  padding-top: 30rpx;
}

.divider {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 20rpx;
}

.btn-dev {
  background: #fff7e6;
  color: #b89437;
  border: 2rpx dashed #c8a45c;
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 20rpx;
}
