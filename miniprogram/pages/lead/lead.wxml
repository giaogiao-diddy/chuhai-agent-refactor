<view class="page">
  <view class="container">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-box">
      <text>加载中...</text>
    </view>

    <!-- 已解锁 / 正常内容 -->
    <view wx:else class="unlock-content">
      <!-- 标题 -->
      <view class="header">
        <view class="title">添加企业微信，解锁完整报告</view>
        <view class="subtitle">添加顾问后，系统确认成功即可自动解锁</view>
      </view>

      <!-- 二维码区域 -->
      <view class="card qrcode-card">
        <image
          wx:if="{{qrCodeUrl}}"
          class="qrcode-img"
          src="{{qrCodeUrl}}"
          mode="widthFix"
        />
        <view wx:else class="qrcode-placeholder">
          <view class="qrcode-placeholder-icon">📱</view>
          <view class="qrcode-placeholder-text">企微二维码待配置</view>
        </view>
        <view class="consultant-name">顾问：{{consultantName}}</view>
      </view>

      <!-- 状态提示 -->
      <view class="status-box">
        <view wx:if="{{isUnlocked}}" class="status-success">
          <text>✅ {{message}}</text>
        </view>
        <view wx:else class="status-waiting">
          <text>⏳ {{message}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="actions">
        <button
          wx:if="{{!isUnlocked}}"
          class="btn-primary"
          bindtap="onCheckStatus"
        >
          我已添加，检查解锁状态
        </button>
        <button
          class="btn-secondary"
          bindtap="goBack"
        >
          返回部分报告
        </button>
      </view>

      <!-- 开发工具 -->
      <view wx:if="{{enableMockUnlock && !isUnlocked}}" class="dev-section">
        <view class="divider">开发调试</view>
        <button
          class="btn-dev"
          bindtap="onMockUnlock"
          loading="{{mockUnlocking}}"
        >
          🔧 模拟添加成功（仅开发环境）
        </button>
      </view>
    </view>
  </view>
</view>
