<view class="page">
  <view class="container">
    <!-- 引导 -->
    <view class="lead-header">
      <view class="lead-title">解锁完整报告</view>
      <view class="lead-subtitle">
        提交信息后即可查看完整报告，并获得<text class="highlight">45 分钟 1 对 1 免费解读</text>
      </view>
    </view>

    <!-- 表单 -->
    <view class="card form-card">
      <view class="form-item">
        <view class="form-label">姓名</view>
        <input
          class="form-input"
          placeholder="请输入姓名"
          value="{{name}}"
          data-field="name"
          bindinput="onInput"
          maxlength="16"
        />
      </view>

      <view class="form-item">
        <view class="form-label">电话 / 微信</view>
        <input
          class="form-input"
          placeholder="请输入联系方式"
          value="{{contact}}"
          data-field="contact"
          bindinput="onInput"
          maxlength="32"
        />
      </view>

      <view class="form-item">
        <view class="form-label">公司</view>
        <input
          class="form-input"
          placeholder="请输入公司名称"
          value="{{company}}"
          data-field="company"
          bindinput="onInput"
          maxlength="64"
        />
      </view>

      <view class="form-item">
        <view class="form-label">身份</view>
        <input
          class="form-input"
          placeholder="如：创始人、运营负责人"
          value="{{role}}"
          data-field="role"
          bindinput="onInput"
          maxlength="32"
        />
      </view>
    </view>

    <!-- 提交按钮 -->
    <button
      class="btn-primary"
      bindtap="submitLead"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '解锁完整报告'}}
    </button>

    <view class="privacy-note">
      提交即表示同意将信息提供给顾问进行后续服务
    </view>
  </view>
</view>
