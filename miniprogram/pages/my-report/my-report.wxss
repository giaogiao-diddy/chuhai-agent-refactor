.page {
  min-height: 100vh;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: #999;
}

/* ── 空态 ─────────────────────────────────────── */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 60rpx;
}

.empty-icon {
  margin-bottom: 32rpx;
}

.empty-icon-circle {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  border-radius: 50%;
  background: #eef0f7;
  color: #1a1a2e;
  font-size: 48rpx;
  font-weight: 700;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* ── 报告卡片 ─────────────────────────────────── */
.report-card {
  margin-top: 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-score {
  font-size: 64rpx;
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.1;
}

.card-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.card-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.card-tag {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.unlock-tag {
  margin-top: 12rpx;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  background: #fff3e0;
  color: #e65100;
  font-size: 22rpx;
  font-weight: 500;
}

.unlock-tag-on {
  background: #e8f5e9;
  color: #2e7d32;
}

.card-brief {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #555;
}

.card-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.card-arrow {
  text-align: right;
  font-size: 26rpx;
  color: #c8a45c;
  font-weight: 500;
}
