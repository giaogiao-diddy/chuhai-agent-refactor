.page {
  min-height: 100vh;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: #64748B;
}

/* ── 空态 ─────────────────────────────────────── */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 60rpx;
}

.empty-icon {
  margin-bottom: 32rpx;
}

.empty-icon-circle {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  border-radius: 50%;
  background: #F0FDFA;
  color: #0D9488;
  font-size: 48rpx;
  font-weight: 700;
}

.empty-text {
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #64748B;
  text-align: center;
  line-height: 1.6;
}

/* ── 报告卡片 ─────────────────────────────────── */
.report-card {
  margin-top: 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-score {
  font-size: 64rpx;
  font-weight: 800;
  color: #0D9488;
  line-height: 1.1;
}

.card-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #64748B;
}

.card-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.card-tag {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #0D9488, #0F766E);
  color: #FFFFFF;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.unlock-tag {
  margin-top: 12rpx;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  background: #FFF7ED;
  color: #EA580C;
  font-size: 22rpx;
  font-weight: 500;
}

.unlock-tag-on {
  background: #ECFDF5;
  color: #059669;
}

.card-brief {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #475569;
}

.card-time {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 16rpx;
}

.card-arrow {
  text-align: right;
  font-size: 26rpx;
  color: #10B981;
  font-weight: 500;
}
