<view class="page">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载报告...</text>
  </view>

  <view wx:else class="container">
    <!-- V3 结构化评估模块 -->
    <view
      wx:for="{{structuredSections}}"
      wx:key="title"
      wx:for-item="section"
      class="card"
    >
      <view class="section-title">{{section.title}}</view>
      <view wx:if="{{section.methodTag}}" class="method-tag">{{section.methodTag}}</view>
      <view class="section-text">{{section.content}}</view>
    </view>

    <!-- 维度评分 -->
    <view class="card">
      <view class="section-title">维度评分</view>
      <view
        wx:for="{{dimensionRows}}"
        wx:key="key"
        wx:for-item="dim"
        class="dimension-row"
      >
        <view class="dim-header">
          <view class="dim-name">{{dim.name}}</view>
          <view class="dim-score">{{dim.scoreText}}</view>
        </view>
        <view class="dim-bar-wrap">
          <view class="dim-bar" style="width: {{dim.percent}}%"></view>
        </view>
        <view class="dim-meta">
          <text>{{dim.percentText}}</text>
          <text wx:if="{{dim.comment}}">{{dim.comment}}</text>
        </view>
      </view>
    </view>

    <!-- 推荐路径 -->
    <view class="card">
      <view class="section-title">推荐出海路径</view>
      <view wx:if="{{strategyItems.length}}">
        <view
          wx:for="{{strategyItems}}"
          wx:key="title"
          wx:for-item="item"
          class="mini-card"
        >
          <view class="mini-title">{{item.title}}</view>
          <view wx:if="{{item.steps.length}}" class="path-steps">
            <view
              wx:for="{{item.steps}}"
              wx:key="*this"
              wx:for-item="step"
              class="path-step"
            >
              <view class="path-step-num">{{index + 1}}</view>
              <view class="path-step-text">{{step}}</view>
            </view>
          </view>
          <view wx:else class="section-text">{{item.content}}</view>
        </view>
      </view>
      <view wx:else class="section-text">{{report.recommended_path}}</view>
    </view>

    <!-- 风险提醒 -->
    <view class="card">
      <view class="section-title">风险提醒</view>
      <view wx:if="{{riskCards.length}}">
        <view
          wx:for="{{riskCards}}"
          wx:key="title"
          wx:for-item="risk"
          class="mini-card risk-card"
        >
          <view class="mini-title">{{risk.title}}</view>
          <view class="section-text">{{risk.content}}</view>
        </view>
      </view>
      <view wx:else class="section-text">{{report.risk_reminder}}</view>
    </view>

    <!-- 30 天行动建议 -->
    <view class="card">
      <view class="section-title">30 天行动建议</view>
      <view
        wx:for="{{actionSteps}}"
        wx:key="key"
        wx:for-item="step"
        class="action-step"
      >
        <view class="step-num">{{index + 1}}</view>
        <view class="step-text">
          <view class="step-label">{{step.label}}</view>
          <view class="step-content">{{step.content}}</view>
        </view>
      </view>
    </view>

    <!-- 顾问引导 -->
    <view class="consultant-box">
      <view class="consultant-qr">
        <image
          wx:if="{{qrcodeUrl}}"
          class="qr-image"
          src="{{qrcodeUrl}}"
          mode="aspectFit"
        />
        <view wx:else class="qr-placeholder">
          <view class="qr-placeholder-inner">
            <view class="qr-pattern"></view>
          </view>
          <view class="qr-placeholder-text">添加顾问获取解读</view>
        </view>
      </view>
      <view class="consultant-text">
        添加企业微信顾问，领取 {{benefitMinutes}} 分钟 1 对 1 解读。
      </view>
      <view class="consultant-benefit">
        当前解读权益：<text class="benefit-highlight">{{benefitMinutes}} 分钟</text>
      </view>
    </view>

    <!-- 转发按钮 -->
    <button class="btn-cta share-btn" open-type="share">
      转发好友，升级为 {{benefitMinutes + 10}} 分钟解读
    </button>
  </view>
</view>
