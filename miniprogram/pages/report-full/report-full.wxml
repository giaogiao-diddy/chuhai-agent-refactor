<view class="page">
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载报告...</text>
  </view>

  <view wx:else class="container">
    <!-- 综合结论 -->
    <view class="card">
      <view class="section-title">综合结论</view>
      <view class="summary-grid" wx:if="{{summaryItems.length}}">
        <view
          wx:for="{{summaryItems}}"
          wx:key="title"
          wx:for-item="summary"
          class="summary-item"
        >
          <view class="summary-label">{{summary.title}}</view>
          <view class="summary-content">{{summary.content}}</view>
        </view>
      </view>
      <view wx:else class="section-text">{{report.summary_conclusion}}</view>
    </view>

    <!-- 维度评分 -->
    <view class="card">
      <view class="section-title">维度评分</view>
      <view
        wx:for="{{dimensionRows}}"
        wx:key="key"
        wx:for-item="dim"
        class="dimension-row"
      >
        <view class="dim-header">
          <view class="dim-name">{{dim.name}}</view>
          <view class="dim-score">{{dim.scoreText}}</view>
        </view>
        <view class="dim-bar-wrap">
          <view class="dim-bar" style="width: {{dim.percent}}%"></view>
        </view>
        <view class="dim-meta">
          <text>{{dim.percentText}}</text>
          <text wx:if="{{dim.comment}}">{{dim.comment}}</text>
        </view>
      </view>
    </view>

    <!-- 推荐路径 -->
    <view class="card">
      <view class="section-title">推荐出海路径</view>
      <view class="section-text">{{report.recommended_path}}</view>
    </view>

    <!-- 风险提醒 -->
    <view class="card">
      <view class="section-title">风险提醒</view>
      <view class="section-text">{{report.risk_reminder}}</view>
    </view>

    <!-- 30 天行动建议 -->
    <view class="card">
      <view class="section-title">30 天行动建议</view>
      <view
        wx:for="{{report.action_plan_30days}}"
        wx:key="*this"
        wx:for-item="step"
        class="action-step"
      >
        <view class="step-num">{{index + 1}}</view>
        <view class="step-text">{{step}}</view>
      </view>
    </view>

    <!-- 顾问引导 -->
    <view class="consultant-box">
      <view class="consultant-qr">
        <view class="qr-placeholder">
          <view class="qr-placeholder-title">企微二维码</view>
          <view class="qr-placeholder-text">请替换为顾问二维码</view>
        </view>
      </view>
      <view class="consultant-text">
        {{report.consultant_guide}}
      </view>
      <view class="consultant-benefit">
        当前解读权益：<text class="benefit-highlight">{{benefitMinutes}} 分钟</text>
      </view>
    </view>

    <!-- 转发按钮 -->
    <button class="btn-primary share-btn" open-type="share">
      转发好友，升级为 {{benefitMinutes + 10}} 分钟解读
    </button>
  </view>
</view>
