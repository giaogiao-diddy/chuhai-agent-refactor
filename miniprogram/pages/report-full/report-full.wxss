.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: #64748B;
}

/* ── 内容卡片 ─────────────────────────────────── */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F766E;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.section-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

.method-tag {
  display: inline-block;
  max-width: 100%;
  padding: 8rpx 16rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  background: #E6F4EA;
  color: #0F766E;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.mini-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.mini-card:last-child {
  border-bottom: none;
}

.mini-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.risk-card .mini-title {
  color: #B45309;
}

/* ── 维度评分 ─────────────────────────────────── */
.dimension-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.dimension-row:last-child {
  border-bottom: none;
}

.dim-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dim-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
  flex: 1;
  min-width: 0;
}

.dim-bar-wrap {
  height: 12rpx;
  background: #CBD5E1;
  border-radius: 6rpx;
  overflow: hidden;
}

.dim-bar {
  height: 100%;
  background: linear-gradient(90deg, #0D9488, #10B981);
  border-radius: 6rpx;
  min-width: 12rpx;
  transition: width 0.6s ease;
}

.dim-score {
  font-size: 30rpx;
  font-weight: 700;
  color: #0D9488;
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.dim-meta {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748B;
}

.dim-meta text:first-child {
  display: none;
}

.path-steps {
  padding-top: 4rpx;
}

.path-step {
  position: relative;
  display: flex;
  gap: 16rpx;
  padding: 0 0 22rpx;
}

.path-step:last-child {
  padding-bottom: 0;
}

.path-step:not(:last-child)::after {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 40rpx;
  bottom: 4rpx;
  width: 2rpx;
  background: #CCFBF1;
}

.path-step-num {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #0D9488;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.path-step-text {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  color: #475569;
  line-height: 1.7;
}

/* ── 行动步骤 ─────────────────────────────────── */
.action-step {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.action-step:last-child {
  border-bottom: none;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #0D9488;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.step-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.75;
  flex: 1;
}

.step-label {
  display: inline-block;
  margin-bottom: 6rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.4;
}

.step-content {
  line-height: 1.75;
}

/* ── 顾问区域 ─────────────────────────────────── */
.consultant-box {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  margin-top: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(13, 148, 136, 0.04);
}

.consultant-qr {
  margin-bottom: 24rpx;
}

.qr-placeholder {
  width: 320rpx;
  height: 320rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E2E8F0;
  background: #F8FAFC;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.qr-pattern {
  width: 100rpx;
  height: 100rpx;
  background:
    linear-gradient(45deg, #0D9488 25%, transparent 25%),
    linear-gradient(-45deg, #0D9488 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #0D9488 75%),
    linear-gradient(-45deg, transparent 75%, #0D9488 75%);
  background-size: 32rpx 32rpx;
  background-position: 0 0, 0 16rpx, 16rpx -16rpx, -16rpx 0;
  opacity: 0.12;
  border-radius: 8rpx;
}

.qr-placeholder-text {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748B;
}

.consultant-text {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.consultant-benefit {
  font-size: 28rpx;
  color: #1E293B;
}

.benefit-highlight {
  color: #10B981;
  font-weight: 700;
  font-size: 36rpx;
}

/* ── 转发按钮 ─────────────────────────────────── */
.share-btn {
  margin-top: 32rpx;
}
