.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: #999;
}

/* ── 分数卡片 ─────────────────────────────────── */
.score-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  text-align: center;
  padding: 48rpx 32rpx 40rpx;
}

.score-number {
  font-size: 96rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
}

.tag-badge {
  display: inline-block;
  margin-top: 20rpx;
  padding: 10rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* ── 深→浅过渡 ───────────────────────────────── */
.score-transition {
  height: 24rpx;
  background: linear-gradient(180deg, #16213e 0%, #f0f1f5 100%);
}

/* ── 内容卡片 ─────────────────────────────────── */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* ── 优势/风险列表 ────────────────────────────── */
.list-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.list-item:last-child {
  border-bottom: none;
}

.bullet-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 16rpx;
}

.bullet-success {
  background: #2e7d32;
  box-shadow: 0 0 0 6rpx rgba(46, 125, 50, 0.15);
}

.bullet-warning {
  background: #e65100;
  box-shadow: 0 0 0 6rpx rgba(230, 81, 0, 0.12);
}

/* ── 解锁区域 ─────────────────────────────────── */
.unlock-box {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.unlock-hint {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
