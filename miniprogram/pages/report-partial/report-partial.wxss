.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: #64748B;
}

/* ── 分数卡片 ─────────────────────────────────── */
.score-card {
  background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
  text-align: center;
  padding: 48rpx 32rpx 40rpx;
}

.score-number {
  font-size: 96rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
}

.tag-badge {
  display: inline-block;
  margin-top: 20rpx;
  padding: 10rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

/* ── 深→浅过渡 ───────────────────────────────── */
.score-transition {
  height: 24rpx;
  background: linear-gradient(180deg, #0F766E 0%, #F8FAFC 100%);
}

/* ── 内容卡片 ─────────────────────────────────── */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F766E;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.section-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

/* ── 优势/风险列表 ────────────────────────────── */
.list-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.list-item:last-child {
  border-bottom: none;
}

.bullet-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 16rpx;
}

.bullet-success {
  background: #059669;
  box-shadow: 0 0 0 6rpx rgba(5, 150, 105, 0.14);
}

.bullet-warning {
  background: #EA580C;
  box-shadow: 0 0 0 6rpx rgba(234, 88, 12, 0.12);
}

/* ── 解锁区域 ─────────────────────────────────── */
.unlock-box {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.unlock-hint {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
