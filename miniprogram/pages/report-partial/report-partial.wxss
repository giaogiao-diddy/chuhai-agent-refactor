.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: #999;
}

/* ── 分数卡片 ─────────────────────────────────── */
.score-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  text-align: center;
  padding: 48rpx 32rpx;
}

.score-number {
  font-size: 96rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.tag-badge {
  display: inline-block;
  margin-top: 20rpx;
  padding: 10rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* ── 内容卡片 ─────────────────────────────────── */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.list-item {
  padding: 14rpx 0;
  font-size: 28rpx;
  line-height: 1.6;
  border-bottom: 1rpx solid #f8f8f8;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-good {
  color: #2e7d32;
}

.list-item-risk {
  color: #e65100;
}

/* ── 解锁区域 ─────────────────────────────────── */
.unlock-box {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.unlock-hint {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
