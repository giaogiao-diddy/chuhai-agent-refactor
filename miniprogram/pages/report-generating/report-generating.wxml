<view class="page">
  <view class="container">
    <!-- 加载动画 -->
    <view class="loader-box">
      <view class="loader-ring"></view>
      <view class="loader-icon">🌊</view>
    </view>

    <view class="title">报告生成中...</view>
    <view class="subtitle">正在分析您的出海准备度</view>

    <!-- 超时提示 -->
    <view class="timeout-hint" wx:if="{{showTimeoutHint}}">
      报告正在精细生成中，请稍候
    </view>
  </view>
</view>
