.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.container {
  text-align: center;
}

/* ── 加载动画 ─────────────────────────────────── */
.loader-box {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 48rpx;
}

.loader-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
  border-top-color: #fff;
  animation: spin 1.2s linear infinite;
}

.loader-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 60rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 文字 ─────────────────────────────────────── */
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.timeout-hint {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}
