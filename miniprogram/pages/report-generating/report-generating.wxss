.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0D9488 0%, #0F766E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.container {
  text-align: center;
}

.loader-box {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 48rpx;
}

.loader-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.12);
  border-top-color: #10B981;
  animation: spin 1.2s linear infinite;
}

.loader-brand {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 36rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  padding: 0 48rpx;
}

.timeout-hint {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}
