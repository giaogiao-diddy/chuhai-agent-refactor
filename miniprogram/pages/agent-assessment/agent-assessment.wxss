/* ── 全局 ─────────────────────────────────── */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F8FAFC;
}

/* ── 顶部 Header ──────────────────────────── */
.agent-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
  flex-shrink: 0;
}

.agent-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0D9488, #10B981);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-inner {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.agent-info {
  flex: 1;
}

.agent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 4rpx;
}

.agent-subtitle {
  font-size: 22rpx;
  color: #94A3B8;
  line-height: 1.4;
}

/* ── 对话滚动区 ───────────────────────────── */
.chat-area {
  flex: 1;
  overflow-y: auto;
}

.message-list {
  padding: 24rpx;
  padding-bottom: 8rpx;
}

/* ── 消息行 ────────────────────────────────── */
.msg-row {
  display: flex;
  margin-bottom: 24rpx;
}

.msg-row-user {
  justify-content: flex-end;
}

.msg-row-assistant {
  justify-content: flex-start;
}

/* ── 气泡 ──────────────────────────────────── */
.msg-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
  border-radius: 16rpx;
}

.msg-bubble-user {
  background: linear-gradient(135deg, #0D9488, #10B981);
  color: #FFFFFF;
  border-top-right-radius: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(13, 148, 136, 0.15);
}

.msg-bubble-assistant {
  background: #FFFFFF;
  color: #334155;
  border-top-left-radius: 4rpx;
  box-shadow: 0 4rpx 24rpx rgba(13, 148, 136, 0.03);
}

/* ── 光标闪烁 ──────────────────────────────── */
.cursor-blink {
  color: #0D9488;
  animation: blink 0.8s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ── 底部控制区 ────────────────────────────── */
.bottom-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E2E8F0;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #F1F5F9;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1E293B;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #0D9488, #10B981);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 72rpx;
}

.send-btn.sending {
  opacity: 0.7;
}

.send-btn[disabled] {
  background: #CBD5E1;
  color: #94A3B8;
}

.btn-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── 生成报告按钮 ──────────────────────────── */
.finish-row {
  padding: 8rpx 0;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(245, 158, 11, 0.25);
}

/* ── 安全区 ────────────────────────────────── */
.safe-bottom {
  height: env(safe-area-inset-bottom);
  background: #FFFFFF;
  flex-shrink: 0;
}
