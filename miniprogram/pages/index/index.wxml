<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <!-- 主内容 -->
  <view wx:else class="container">
    <!-- Hero 区域 -->
    <view class="hero">
      <!-- 品牌 Logo 占位色块 — 后续替换为真实 logo 图片 -->
      <view class="hero-logo">
        <view class="hero-logo-inner">LB</view>
      </view>
      <view class="hero-title">罗宾出海分析</view>
      <view class="hero-subtitle">3 分钟完成测评 · 获得专属出海评估报告</view>
    </view>

    <!-- 引导卡片 -->
    <view class="card guide-card">
      <view class="guide-item">
        <view class="guide-num">1</view>
        <text class="guide-text">完成 18 道出海测评题</text>
      </view>
      <view class="guide-item">
        <view class="guide-num">2</view>
        <text class="guide-text">获取出海准备度评分</text>
      </view>
      <view class="guide-item">
        <view class="guide-num">3</view>
        <text class="guide-text">添加企微顾问，解锁完整评估报告</text>
      </view>
    </view>

    <!-- 开始按钮 — CTA 暖金 -->
    <button
      class="btn-cta start-btn"
      bindtap="startAssessment"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >
      开始测评
    </button>

    <!-- 查看报告入口 -->
    <view class="my-report-link" bindtap="goToMyReport">
      查看我的报告
      <text class="link-arrow">→</text>
    </view>
  </view>
</view>
