<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <!-- 主内容 -->
  <view wx:else class="container">
    <!-- Hero 区域 -->
    <view class="hero">
      <!-- 品牌 Logo 占位色块 — 后续替换为真实 logo 图片 -->
      <view class="hero-logo">
        <view class="hero-logo-inner">DF</view>
      </view>
      <view class="hero-title">深度未来</view>
      <view class="hero-subtitle">20-30 分钟完成企业出海可行性评估</view>
    </view>

    <!-- 引导卡片 -->
    <view class="card guide-card">
      <view class="guide-item">
        <view class="guide-num">1</view>
        <text class="guide-text">静下心完成一份动态出海评估问卷</text>
      </view>
      <view class="guide-item">
        <view class="guide-num">2</view>
        <text class="guide-text">获得行业、市场、路径、风险与第一步动作判断</text>
      </view>
      <view class="guide-item">
        <view class="guide-num">3</view>
        <text class="guide-text">添加企微顾问，解锁完整分析与 1 对 1 解读</text>
      </view>
    </view>

    <!-- 开始按钮 — CTA 暖金 -->
    <button
      class="btn-cta start-btn"
      bindtap="startAssessment"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >
      开始测评
    </button>

    <!-- 查看报告入口 -->
    <view class="my-report-link" bindtap="goToMyReport">
      查看我的报告
      <text class="link-arrow">→</text>
    </view>
  </view>
</view>
