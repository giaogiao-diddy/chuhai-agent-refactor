<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <!-- 主内容 -->
  <view wx:else class="container">
    <!-- Hero 区域 -->
    <view class="hero">
      <view class="hero-icon">🌊</view>
      <view class="hero-title">罗宾出海分析</view>
      <view class="hero-subtitle">3 分钟完成测评 · 获得专属出海评估报告</view>
    </view>

    <!-- 引导卡片 -->
    <view class="card guide-card">
      <view class="guide-item">
        <text class="guide-num">1</text>
        <text class="guide-text">完成 15 道选择题</text>
      </view>
      <view class="guide-item">
        <text class="guide-num">2</text>
        <text class="guide-text">获取出海准备度评分</text>
      </view>
      <view class="guide-item">
        <text class="guide-num">3</text>
        <text class="guide-text">解锁完整评估报告</text>
      </view>
    </view>

    <!-- 开始按钮 -->
    <button class="btn-primary start-btn" bindtap="startAssessment" loading="{{submitting}}" disabled="{{submitting}}">
      开始测评
    </button>

    <!-- 查看报告入口 -->
    <view class="my-report-link" bindtap="goToMyReport">
      查看我的报告 →
    </view>
  </view>
</view>
