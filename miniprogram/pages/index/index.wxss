.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 58%, #f0f1f5 58%);
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #fff;
  font-size: 28rpx;
}

/* ── Hero ─────────────────────────────────────── */
.hero {
  text-align: center;
  padding: 72rpx 0 56rpx;
}

.hero-logo {
  display: flex;
  justify-content: center;
  margin-bottom: 28rpx;
}

.hero-logo-inner {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.12);
  border: 3rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* ── 引导卡片 ─────────────────────────────────── */
.guide-card {
  margin-top: 16rpx;
}

.guide-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.guide-item:last-child {
  border-bottom: none;
}

.guide-num {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.guide-text {
  font-size: 28rpx;
  color: #333;
}

/* ── 按钮 ─────────────────────────────────────── */
.start-btn {
  margin-top: 48rpx;
}

/* ── 我的报告 ─────────────────────────────────── */
.my-report-link {
  text-align: center;
  color: #555;
  font-size: 28rpx;
  margin-top: 32rpx;
  padding: 16rpx;
}

.link-arrow {
  color: #c8a45c;
  font-weight: 600;
  margin-left: 4rpx;
}
