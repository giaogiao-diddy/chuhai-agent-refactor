.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 60%, #f5f5f5 60%);
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #fff;
  font-size: 28rpx;
}

/* ── Hero ─────────────────────────────────────── */
.hero {
  text-align: center;
  padding: 80rpx 0 60rpx;
}

.hero-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── 引导卡片 ─────────────────────────────────── */
.guide-card {
  margin-top: 16rpx;
}

.guide-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.guide-item:last-child {
  border-bottom: none;
}

.guide-num {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.guide-text {
  font-size: 28rpx;
  color: #333;
}

/* ── 按钮 ─────────────────────────────────────── */
.start-btn {
  margin-top: 48rpx;
}

/* ── 我的报告 ─────────────────────────────────── */
.my-report-link {
  text-align: center;
  color: #1a1a2e;
  font-size: 28rpx;
  margin-top: 32rpx;
  padding: 16rpx;
}
