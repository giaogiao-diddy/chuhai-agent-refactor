.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ── 进度条 ───────────────────────────────────── */
.progress-bar {
  height: 6rpx;
  background: #CBD5E1;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0D9488, #10B981);
  transition: width 0.35s ease;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: #64748B;
  padding: 12rpx 0;
}

/* ── 题号圆点导航 ──────────────────────────────── */
.question-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  padding: 4rpx 20rpx 12rpx;
}

.question-dot {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  margin: 10rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  background: #FFFFFF;
  color: #64748B;
  font-size: 22rpx;
  font-weight: 600;
  position: relative;
}

.question-dot::after {
  content: "";
  position: absolute;
  top: -12rpx;
  left: -12rpx;
  right: -12rpx;
  bottom: -12rpx;
}

.question-dot-answered {
  border-color: #0D9488;
  background: #F0FDFA;
  color: #0F766E;
}

.question-dot-current {
  background: #0D9488;
  border-color: #0D9488;
  color: #FFFFFF;
  box-shadow: 0 6rpx 16rpx rgba(13, 148, 136, 0.18);
}

/* ── 题目卡片 ─────────────────────────────────── */
.question-card {
  margin-top: 24rpx;
}

.question-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.6;
}

.question-desc {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 12rpx;
}

/* ── 选项列表 ─────────────────────────────────── */
.options-list {
  margin-top: 36rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  margin-bottom: 20rpx;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  transition: border-color 0.15s ease, background-color 0.15s ease;
}

.option-item:active {
  background: #F0FDFA;
}

.option-active {
  border-color: #0D9488;
  background: #ECFDF5;
}

.option-disabled {
  opacity: 0.6;
  pointer-events: none;
}

.option-marker {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-radio {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  background: #FFFFFF;
  transition: all 0.2s ease;
}

.option-radio-checked {
  border-color: #0D9488;
  background: #0D9488;
  box-shadow: 0 0 0 6rpx rgba(13, 148, 136, 0.12) inset;
}

.option-text {
  font-size: 28rpx;
  color: #1E293B;
  line-height: 1.5;
  flex: 1;
}

/* ── 文本输入题 ───────────────────────────────── */
.text-answer-box {
  margin-top: 36rpx;
}

.text-answer-input {
  box-sizing: border-box;
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1E293B;
}

.text-answer-input:focus {
  border-color: #0D9488;
}

.submit-text-btn {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #0D9488;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
}

.submit-text-btn[disabled] {
  background: #CBD5E1;
  color: #FFFFFF;
}

/* ── 底部导航 ─────────────────────────────────── */
.nav-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #E2E8F0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  border-radius: 36rpx;
  border: 2rpx solid #0D9488;
  background: #FFFFFF;
  color: #0D9488;
}

.nav-btn[disabled] {
  border-color: #CBD5E1;
  color: #CBD5E1;
}

.nav-hint {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 12rpx;
}
