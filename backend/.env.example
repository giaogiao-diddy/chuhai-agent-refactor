APP_NAME=chuhai-agent
APP_VERSION=0.1.0
ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chuhai_agent
CORS_ORIGINS=*

# ── 鉴权 ──
# JWT_SECRET_KEY: 至少 32 字符的随机字符串。生成方式：
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_32_chars_or_longer_random_secret
JWT_EXPIRE_MINUTES=10080

# 微信开放平台 OAuth 配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_REDIRECT_URI=https://your-domain.com/auth/callback
WECHAT_QR_URL=

# ── Admin ──
ADMIN_API_KEY=your_admin_api_key_here

# ── AI ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://your-embedding-api.example.com
