# 环境变量配置模板（微信云托管版）
# 复制此文件为 .env 并填入实际值
# 在云托管控制台 → 环境变量中配置这些值
# cp .env.example .env

# ==================== 数据库 ====================
# 推荐使用云开发 MySQL（TencentDB）
LB_DB_HOST=localhost
LB_DB_PORT=3306
LB_DB_USER=root
LB_DB_PASSWORD=
LB_DB_NAME=luobin_agent

# ==================== AI (DeepSeek) ====================
LB_LLM_API_KEY=
LB_LLM_BASE_URL=https://api.deepseek.com
LB_LLM_MODEL=deepseek-chat
LB_LLM_TIMEOUT=15

# ==================== JWT ====================
LB_JWT_SECRET=your-secret-key-change-in-production
LB_JWT_ALGORITHM=HS256
LB_JWT_EXPIRE_HOURS=72

# ==================== 微信小程序 ====================
LB_WX_APPID=
LB_WX_SECRET=

# ==================== 云托管 ====================
# CloudBase 环境 ID（云托管控制台可见）
LB_CLOUDBASE_ENV_ID=

# ==================== 服务器 ====================
# 云托管会注入 PORT 环境变量
LB_SERVER_HOST=0.0.0.0
LB_SERVER_PORT=8000
LB_DEBUG=false

# ==================== 报告配置 ====================
LB_AI_REPORT_ENABLED=true
LB_REPORT_POLL_INTERVAL=1.5
LB_REPORT_GENERATE_TIMEOUT=20
