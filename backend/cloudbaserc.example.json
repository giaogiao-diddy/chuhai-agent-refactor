{
  "envId": "<your-env-id>",
  "version": "2.0",
  "cloudrun": {
    "serviceName": "luobin-agent",
    "port": 80,
    "dockerfilePath": "Dockerfile",
    "envVariables": {
      "LB_DB_HOST": "<mysql-host>",
      "LB_DB_PORT": "3306",
      "LB_DB_USER": "root",
      "LB_DB_PASSWORD": "<mysql-password>",
      "LB_DB_NAME": "luobin_agent",
      "LB_LLM_API_KEY": "<your-deepseek-key>",
      "LB_LLM_BASE_URL": "https://api.deepseek.com",
      "LB_LLM_MODEL": "deepseek-chat",
      "LB_JWT_SECRET": "<random-64-char-string>",
      "LB_WX_APPID": "<your-wx-appid>",
      "LB_WX_SECRET": "<your-wx-secret>"
    }
  }
}
